<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_laundry_pickup_wizard_form" model="ir.ui.view">
        <field name="name">laundry.pickup.wizard.form</field>
        <field name="model">laundry.pickup.wizard</field>
        <field name="arch" type="xml">
            <form string="Pickup / Delivery Confirmation">
                <group>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="order_type" readonly="1"/>
                    </group>
                    <group>
                        <field name="staff_name" required="1"/>
                        <field name="staff_phone"/>
                    </group>
                </group>
                <group>
                    <field name="notes" placeholder="Optional notes..."/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
