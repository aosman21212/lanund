<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_laundry_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o" t-key="o.id">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <h2 class="text-primary">Laundry Order</h2>
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-bold">Order #:</td>
                                        <td><t t-esc="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Date:</td>
                                        <td><t t-esc="o.date" t-options="{'widget': 'date'}"/></td>
                                    </tr>
                                    <tr t-if="o.deadline">
                                        <td class="fw-bold">Deadline:</td>
                                        <td><t t-esc="o.deadline" t-options="{'widget': 'date'}"/></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Type:</td>
                                        <td>
                                            <t t-if="o.order_type == 'pickup'">Pick Up</t>
                                            <t t-else="">Home Delivery</t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Status:</td>
                                        <td>
                                            <span class="badge bg-info">
                                                <t t-esc="dict(o.fields_get(['state'])['state']['selection'])[o.state]"/>
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <h4>Customer</h4>
                                <address>
                                    <strong><t t-esc="o.customer_id.name"/></strong><br/>
                                    <t t-if="o.customer_id.street"><t t-esc="o.customer_id.street"/><br/></t>
                                    <t t-if="o.customer_id.city"><t t-esc="o.customer_id.city"/></t>
                                    <t t-if="o.customer_id.country_id">, <t t-esc="o.customer_id.country_id.name"/></t>
                                    <t t-if="o.customer_id.phone"><br/><t t-esc="o.customer_id.phone"/></t>
                                    <t t-if="o.customer_id.email"><br/><t t-esc="o.customer_id.email"/></t>
                                    <t t-if="o.customer_ref"><br/>Ref: <t t-esc="o.customer_ref"/></t>
                                </address>
                            </div>
                        </div>

                        <!-- Cloth Lines Table -->
                        <h4 class="mt-3">Cloth Items</h4>
                        <table class="table table-striped table-sm">
                            <thead class="table-primary">
                                <tr>
                                    <th>#</th>
                                    <th>Cloth Type</th>
                                    <th>Size</th>
                                    <th>Washing Service</th>
                                    <th>Extra Services</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.cloth_line_ids" t-as="line" t-key="line.id">
                                    <tr>
                                        <td><t t-esc="line_index + 1"/></td>
                                        <td><t t-esc="line.cloth_type_id.name"/></td>
                                        <td><t t-esc="line.size_id.name or '-'"/></td>
                                        <td><t t-esc="line.service_id.name"/></td>
                                        <td>
                                            <t t-foreach="line.extra_service_ids" t-as="es" t-key="es.id">
                                                <span class="badge bg-secondary me-1"><t t-esc="es.name"/></span>
                                            </t>
                                        </td>
                                        <td class="text-end"><t t-esc="line.qty"/></td>
                                        <td class="text-end">
                                            <t t-esc="line.washing_price"
                                               t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="line.subtotal"
                                               t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr t-if="line.notes">
                                        <td colspan="8" class="text-muted fst-italic ps-4">
                                            Note: <t t-esc="line.notes"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Charges Summary -->
                        <div class="row mt-3">
                            <div class="col-6 offset-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td>Washing Charge:</td>
                                        <td class="text-end">
                                            <t t-esc="o.washing_charge"
                                               t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Extra Service Charge:</td>
                                        <td class="text-end">
                                            <t t-esc="o.extra_charge"
                                               t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr t-if="o.delivery_charge">
                                        <td>Delivery Charge:</td>
                                        <td class="text-end">
                                            <t t-esc="o.delivery_charge"
                                               t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr class="fw-bold table-primary">
                                        <td>Total Amount:</td>
                                        <td class="text-end">
                                            <t t-esc="o.total_amount"
                                               t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Staff Info -->
                        <t t-if="o.staff_name or o.picked_up_date">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <h4>Pickup / Delivery Information</h4>
                                    <p t-if="o.staff_name">
                                        <strong>Staff: </strong><t t-esc="o.staff_name"/>
                                        <t t-if="o.staff_phone"> - <t t-esc="o.staff_phone"/></t>
                                    </p>
                                    <p t-if="o.picked_up_date">
                                        <strong>Date: </strong>
                                        <t t-esc="o.picked_up_date" t-options="{'widget': 'datetime'}"/>
                                    </p>
                                </div>
                            </div>
                        </t>

                        <!-- Terms -->
                        <t t-if="o.terms">
                            <div class="row mt-3">
                                <div class="col-12">
                                    <h4>Terms &amp; Conditions</h4>
                                    <p><t t-esc="o.terms"/></p>
                                </div>
                            </div>
                        </t>

                        <!-- Footer Signature Area -->
                        <div class="row mt-5">
                            <div class="col-6">
                                <p class="border-top pt-2">Customer Signature</p>
                            </div>
                            <div class="col-6">
                                <p class="border-top pt-2">Staff Signature</p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
