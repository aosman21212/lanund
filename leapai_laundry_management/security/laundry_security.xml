<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Laundry Management Privilege (visible category in Settings > Users) -->
        <record id="res_groups_privilege_leapai_laundry_management" model="res.groups.privilege">
            <field name="name">Laundry Management</field>
            <field name="category_id" ref="base.module_category_services_field_service"/>
            <field name="sequence">100</field>
        </record>

        <!-- Groups -->
        <record id="laundry_user_group" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="res_groups_privilege_leapai_laundry_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="sequence">10</field>
        </record>

        <record id="laundry_manager_group" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_leapai_laundry_management"/>
            <field name="implied_ids" eval="[(4, ref('laundry_user_group'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="sequence">20</field>
        </record>
    </data>
</odoo>
